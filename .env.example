# Firebase — 미설정 시 src/firebase/config.js 의 기본값(hosing-5913f) 사용
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Cloudinary (사진첩) — 미설정 시 사진 업로드 비활성화
# cloudinary.com → Settings → Upload → unsigned preset 생성
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# FCM 푸시 알림 — 미설정 시 마이페이지 알림 토글 비활성화
# Firebase Console → 프로젝트 설정 → Cloud Messaging → 웹 푸시 인증서 → 키 쌍 생성
VITE_FIREBASE_VAPID_KEY=
