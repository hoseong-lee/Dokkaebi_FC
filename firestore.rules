rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ───── 헬퍼 함수 ─────
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email.lower();
    }

    function isAllowed() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/allowedEmails/$(userEmail())) &&
        get(/databases/$(database)/documents/allowedEmails/$(userEmail())).data.active == true;
    }

    function isAdmin() {
      return isAllowed() &&
        get(/databases/$(database)/documents/allowedEmails/$(userEmail())).data.role == 'admin';
    }

    // ───── 컬렉션별 규칙 ─────

    match /users/{uid} {
      allow read: if isAllowed();
      // 본인 문서는 upsert 가능 (로그인 시), 관리자는 모두 수정 가능
      allow write: if isSignedIn() && (request.auth.uid == uid || isAdmin());
    }

    match /allowedEmails/{email} {
      // 본인 이메일은 로그인 시 검증용으로 읽기 허용
      allow read: if isSignedIn() && (userEmail() == email || isAdmin());
      allow write: if isAdmin();
    }

    match /players/{playerId} {
      allow read: if isAllowed();
      allow write: if isAdmin();
    }

    match /seasons/{seasonId} {
      allow read: if isAllowed();
      allow write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if isAllowed();
      allow write: if isAdmin();

      match /rsvps/{uid} {
        allow read: if isAllowed();
        // 본인 RSVP만 쓰기 가능
        allow write: if isAllowed() && request.auth.uid == uid;
      }
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAllowed();   // 누구나 로그 남길 수는 있음
      allow update, delete: if false; // 수정/삭제 불가
    }
  }
}
