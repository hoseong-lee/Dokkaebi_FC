rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /players/{playerId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /matches/{matchId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
